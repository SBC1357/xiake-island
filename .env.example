# 侠客岛 - 环境变量配置示例

# ============================================
# LLM Provider 配置
# ============================================

# Provider 类型: "fake" 或 "openai"
# - fake: 使用假 provider，返回固定响应（开发和测试用）
# - openai: 使用真实 OpenAI API
LLM_PROVIDER=fake

# 模型名称（OpenAI 模式下必须设置）
# - fake 模式下: 可选，默认使用 fake-model
# - openai 模式下: 必须设置为真实模型名，如 gpt-3.5-turbo, gpt-4
#   未设置时会抛出错误，不会静默使用默认值
# LLM_MODEL=gpt-3.5-turbo

# OpenAI API Key（仅在 LLM_PROVIDER=openai 时需要）
# 请从 https://platform.openai.com/api-keys 获取
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI Base URL（可选，默认 https://api.openai.com/v1）
# 如果使用代理或第三方兼容服务，可修改此 URL
# OPENAI_BASE_URL=https://api.openai.com/v1

# LLM 调用超时时间（秒，默认 30）
# LLM_TIMEOUT_SECONDS=30

# LLM 调用最大重试次数（默认 3）
# LLM_MAX_RETRIES=3

# ============================================
# 前端 API 配置
# ============================================

# 后端 API 地址
VITE_API_BASE_URL=http://127.0.0.1:8000